{
  "name": "brpec-sync-server",
  "version": "0.1.0",
  "private": true,
  "description": "Servidor de sync da PWA do BrPec — recebe deltas do capataz e os reconcilia idempotentemente em um SQLite mestre.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev":   "node --watch server.js",
    "test":  "node --test server.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors":           "^2.8.5",
    "express":        "^4.21.0"
  },
  "devDependencies": {
    "supertest":      "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
